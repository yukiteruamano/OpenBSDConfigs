#
# csh login file

if ( ! $?TERMCAP ) then
	tset -IQ '-munknown:?vt220' $TERM
endif

stty	newcrt crterase

set	savehist=100
set	ignoreeof

setenv	EXINIT		'set ai sm noeb'

# Personal configuration

# Personal configs
setenv EDITOR   'nvim'
setenv PAGER    'less'

# Personal exports
setenv QT_QPA_PLATFORMTHEME 'qt6ct'
setenv XDG_RUNTIME_DIR '/tmp/run/user/1000'
setenv AUDIODEVICE 'snd/1'
setenv AUDIOPLAYDEVICE 'snd/1'
setenv AUDIORECDEVICE 'snd/1'
setenv GOPATH '/home/yukiteru/.golang'
setenv PARALLEL_BUILD 'YES'
setenv MAKE_JOBS 4
setenv RUST_SRC_PATH '/usr/local/lib/rustlib/src/rust/library'
setenv CVSROOT 'anoncvs@anoncvs.spacehopper.org:/cvs'
setenv MOZ_ACCELERATED 1
setenv MOZ_WEBRENDER 1
setenv XCURSOR_SIZE 16
setenv FREETYPE_PROPERTIES "cff:no-stem-darkening=0.0 autofitter:no-stem-darkening=0.0"
setenv XKB_DEFAULT_LAYOUT "us"
setenv XKB_DEFAULT_VARIANT "intl"

# Language setting for user
setenv LANG 'es_ES.UTF-8'
setenv CHARSET 'UTF-8'

if (-x /usr/games/fortune) /usr/games/fortune
